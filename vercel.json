{
  "version": 2,
  "installCommand": "npm install --prefix client",
  "buildCommand": "npm run prepare-client-env && npm run build --prefix client",
  "outputDirectory": "client/dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "toisouljahacademy.com"
        }
      ],
      "destination": "https://www.toisouljahacademy.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://syzmeku-api.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
